# Supabase — Genie creates her own project at supabase.com
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# These go in Supabase Edge Function secrets (not in this file):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ENCRYPTION_KEY=any-random-string-at-least-32-chars
#
# Optional env var fallbacks (API keys are stored encrypted in DB via Settings page):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...
# GOOGLE_API_KEY=AIza...
